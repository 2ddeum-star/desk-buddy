{
  "name": "desk-buddy",
  "version": "1.0.2",
  "description": "OS 전역 마우스/키보드 입력을 따라 동작하는 데스크톱 마스코트 (Electron)",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.4"
  },
  "build": {
    "appId": "co.kr.2359.deskbuddy",
    "productName": "Desk Buddy",
    "files": [
      "index.html",
      "style.css",
      "main.js",
      "electron-main.js",
      "preload.js",
      "assets/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**"
    ]
  }
}
